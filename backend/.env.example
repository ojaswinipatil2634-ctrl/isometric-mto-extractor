APP_NAME=Isometric MTO Extractor
ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25

DATABASE_URL=sqlite:///./data/app.db

# Used by the vision extraction pipeline (app/services/vision_extraction/)
# to produce the actual PIPE/FITTING/FLANGE/VALVE/GASKET/BOLT MTO items,
# and also by Phase 9 Gemini verification. Leave blank to run fully on the
# deterministic mock MTO - the app must (and does) run end-to-end without it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60

# OCR (Phase 3) - safe CPU defaults for local/Windows dev
OCR_LANG=en
OCR_USE_GPU=false
OCR_USE_ANGLE_CLS=true

# Symbol detection (Phase 4) - no weights shipped in this repo; app
# stays fully functional without them (POST /detect returns a clean
# 503 DETECTION_UNAVAILABLE instead of crashing).
YOLO_WEIGHTS_PATH=./data/weights/yolov11_piping.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_DEVICE=cpu

LOG_LEVEL=INFO
